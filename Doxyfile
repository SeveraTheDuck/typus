PROJECT_NAME           = "Typus"
OUTPUT_DIRECTORY       = docs_output
INPUT                  = source/ README.md
RECURSIVE              = YES
USE_MDFILE_AS_MAINPAGE = README.md
OPTIMIZE_OUTPUT_FOR_C  = NO

EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = YES
EXTRACT_STATIC         = YES
EXTRACT_LOCAL_CLASSES  = YES
EXTRACT_LOCAL_METHODS  = YES
HIDE_UNDOC_MEMBERS     = NO

EXTENSION_MAPPING      = hpp=C++
FILE_PATTERNS          = *.cpp *.hpp *.h

HTML_EXTRA_STYLESHEET  = docs/doxygen-awesome.css
GENERATE_TREEVIEW      = YES
DISABLE_INDEX          = NO
FULL_SIDEBAR           = NO
HTML_COLORSTYLE        = LIGHT
MARKDOWN_SUPPORT       = YES
AUTOLINK_SUPPORT       = YES
SUBGROUP_CONTRIBUTIONS = YES
BUILTIN_STL_SUPPORT    = YES

HAVE_DOT               = YES
DOT_IMAGE_FORMAT       = svg
INTERACTIVE_SVG        = YES
GENERATE_LEGEND        = YES
CLASS_GRAPH            = YES
COLLABORATION_GRAPH    = YES
CALL_GRAPH             = YES
CALLER_GRAPH           = YES

GENERATE_LATEX         = NO
GENERATE_HTML          = YES

WARN_IF_UNDOCUMENTED   = YES
SORT_MEMBER_DOCS       = YES
STRIP_FROM_PATH        = source/
